{
  "name": "nps-report",
  "version": "0.1.0",
  "description": "Report broken things in US National Parks — a Hono + Cloudflare Worker API/CLI that wraps the NPS per-park sendemail.cfm contact form (modeled on improvebayarea.com).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "harvest": "tsx scripts/harvest-parks.ts",
    "report": "tsx scripts/report.ts"
  },
  "dependencies": {
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/workers-types": "^4.20251001.0",
    "@types/node": "^25.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.103.0"
  }
}
